RewriteEngine On
# RewriteBase is automatically determined relative to the directory containing .htaccess
# RewriteBase /refractotherm/

# If requested file or directory actually exists, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise route everything to index.php
RewriteRule ^(.*)$ index.php?uri=$1 [QSA,L]
